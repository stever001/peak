# Example environment for the Peak controlled engagement database (MySQL).
# Copy to `.env` and fill in real values. `.env` is gitignored and must NEVER be
# committed. This file contains PLACEHOLDERS ONLY — no real credentials.

# MySQL connection URL used by SQLAlchemy/Alembic (peak/db/session.py, alembic/env.py).
PEAK_DATABASE_URL=mysql+pymysql://user:password@localhost:3306/peak_dev
