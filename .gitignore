# macOS
.DS_Store

# Editor / OS cruft
*.swp
.idea/
.vscode/

# Python virtual environments / bytecode — never commit the local venv (see docs/DATABASE_SCAFFOLD.md)
.venv/
venv/
__pycache__/
*.py[cod]

# Environment — never commit real credentials. .env.example (placeholders) is allowed.
.env
.env.*
!.env.example

# Databases / dumps — never commit data (see docs/DATABASE_SCAFFOLD.md)
*.db
*.sqlite
*.sqlite3
*.sql
dumps/
backups/

# Generated / local data — never commit data artifacts (see docs/FIXTURE_STRATEGY.md)
.generated/
.local/
tmp/
local-fixtures/
